{
  "name": "vala-www",
  "version": "0.0.0",
  "description": "Website of the Vala programming language",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress dev",
    "build": "vitepress build && bun run scripts/generate-atom.mjs",
    "preview": "vitepress preview",
    "format": "prettier --write .",
    "sass:migrate": "sass-migrator module --migrate-deps .vitepress/theme/styles/main.scss",
    "sass:migrate:dry": "sass-migrator module --dry-run --migrate-deps .vitepress/theme/styles/main.scss",
    "sass:migrate:builtins": "sass-migrator module --migrate-deps --built-in-only .vitepress/theme/styles/main.scss"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "prettier": "^3.3.3",
    "sass": "^1.79.4",
    "sass-embedded": "^1.99.0",
    "sass-migrator": "^2.5.7",
    "vitepress": "^1.4.1",
    "vue": "^3.5.12"
  }
}
